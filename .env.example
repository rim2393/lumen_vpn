LUMEN_VERSION=v0.1.9
LUMEN_ENV=production
TZ=UTC

PANEL_DOMAIN=panel.example.com
SUBSCRIPTION_DOMAIN=sub.example.com
AUTH_PORTAL_DOMAIN=
ACME_EMAIL=admin@example.com

LUMEN_HOME=/opt/lumen
LUMEN_DATA_DIR=/opt/lumen/data
LUMEN_BACKUP_DIR=/opt/lumen/backups
LUMEN_SUPPORT_DIR=/opt/lumen/support-bundles
LUMEN_SECRETS_DIR=/opt/lumen/secrets
TLS_CERT_DIR=/etc/nginx/lumen/certs
LUMEN_ACME_ENABLED=true

POSTGRES_IMAGE=postgres:16.3-bookworm@sha256:d0f363f8366fbc3f52d172c6e76bc27151c3d643b870e1062b4e8bfe65baf609
REDIS_IMAGE=redis:7.2.5-bookworm@sha256:3aaec283e6e593bde528077d60280ac1589887067a39273348860837c9346d7e
LUMEN_API_IMAGE=ghcr.io/rim2393/lumen-api:v0.1.9@sha256:8ceb6cb71a26130cc7c017cb10702b220d841e92316eb8afc96e9818db9357b8
LUMEN_WEB_IMAGE=ghcr.io/rim2393/lumen-web:v0.1.9@sha256:7d6aa9a08cf36bead45a82ccb1bacf59eb99d500822eab714c3bd6e66a4601ac
LUMEN_NODE_AGENT_IMAGE=ghcr.io/rim2393/lumen-node-agent:v0.1.9@sha256:918732068399e220dbfc82232d9e1c3528bb9e974eb827c43f0cd5d4c211745f
LUMEN_SUBSCRIPTION_IMAGE=ghcr.io/rim2393/lumen-subscription-page:v0.1.9@sha256:1c608307af7d0370fc0543dfb65bcd57d5cb02639aeeca7f6e7623b2b96defc2

LUMEN_API_PORT=8080
LUMEN_API_INTERNAL_PORT=8000
LUMEN_WEB_PORT=3000
LUMEN_WEB_INTERNAL_PORT=3000
LUMEN_SUBSCRIPTION_PORT=8081
LUMEN_SUBSCRIPTION_INTERNAL_PORT=8080

LUMEN_ALLOW_UNPINNED_IMAGES=false
LUMEN_SKIP_IMAGE_PULL=false
LUMEN_SKIP_PORT_CHECK=false
LUMEN_CONTROL_PLANE_URL=https://panel.example.com
LUMEN_NODE_NAME=manual-node
LUMEN_NODE_STATE_DIR=/opt/lumen-node/state
LUMEN_NODE_SECRETS_DIR=/opt/lumen-node/secrets
LUMEN_DRY_RUN=false
LUMEN_ENABLE_LIVE_SMOKE=false
LUMEN_XRAY_CONFIG_FILE=/var/lib/lumen-node/runtime/xray/config.json
LUMEN_XRAY_LOG_FILE=/var/lib/lumen-node/runtime/xray/xray.log
LUMEN_XRAY_RELOAD_MODE=process
LUMEN_HYSTERIA2_CONFIG_FILE=/var/lib/lumen-node/runtime/hysteria2/config.json
LUMEN_HYSTERIA2_LOG_FILE=/var/lib/lumen-node/runtime/hysteria2/sing-box.log
LUMEN_HYSTERIA2_PID_FILE=/var/lib/lumen-node/runtime/hysteria2/sing-box.pid
LUMEN_HYSTERIA2_RELOAD_MODE=process
LUMEN_OPENVPN_CONFIG_FILE=/var/lib/lumen-node/runtime/openvpn/server.conf
LUMEN_OPENVPN_LOG_FILE=/var/lib/lumen-node/runtime/openvpn/openvpn.log
LUMEN_OPENVPN_PID_FILE=/var/lib/lumen-node/runtime/openvpn/openvpn.pid
LUMEN_OPENVPN_AUTH_SCRIPT=/var/lib/lumen-node/runtime/openvpn/auth-user-pass.sh
LUMEN_OPENVPN_USERS_FILE=/var/lib/lumen-node/runtime/openvpn/users.txt
LUMEN_OPENVPN_RELOAD_MODE=process
LUMEN_TUIC_CONFIG_FILE=/var/lib/lumen-node/runtime/tuic/config.json
LUMEN_TUIC_LOG_FILE=/var/lib/lumen-node/runtime/tuic/sing-box.log
LUMEN_TUIC_PID_FILE=/var/lib/lumen-node/runtime/tuic/sing-box.pid
LUMEN_TUIC_RELOAD_MODE=process
LUMEN_WIREGUARD_CONFIG_FILE=/var/lib/lumen-node/runtime/wireguard/lumen-wg.conf
LUMEN_WIREGUARD_RELOAD_MODE=wg-quick

LICENSE_MODE=free
FREE_NODE_LIMIT=3
LUMEN_CENTRAL_LICENSE_PUBLIC_KEY_B64=
LICENSE_KEY_FILE=/opt/lumen/secrets/license.key
LICENSE_OFFLINE_FILE=/opt/lumen/secrets/offline-license.json
REGISTRY_HOST=ghcr.io
REGISTRY_USERNAME=
REGISTRY_TOKEN_FILE=/opt/lumen/secrets/registry-token
REGISTRY_REQUIRED=false
UPGRADE_BACKUP_PASSPHRASE_FILE=/opt/lumen/secrets/upgrade-backup.pass
LUMEN_RELEASE_PUBLIC_KEY_FILE=/opt/lumen/release-signing.pub
LUMEN_LAST_UPGRADE_STATE=

POSTGRES_PASSWORD=GENERATED_AT_INSTALL
REDIS_PASSWORD=GENERATED_AT_INSTALL
JWT_SECRET=GENERATED_AT_INSTALL
REFRESH_SECRET=GENERATED_AT_INSTALL
API_TOKEN_PEPPER=GENERATED_AT_INSTALL
NODE_TOKEN_PEPPER=GENERATED_AT_INSTALL
SESSION_HASH_PEPPER=GENERATED_AT_INSTALL
LUMEN_BOOTSTRAP_ADMIN_API_KEY=GENERATED_AT_INSTALL
ENCRYPTION_KEY=GENERATED_AT_INSTALL
WEBHOOK_SIGNING_SECRET=GENERATED_AT_INSTALL
NODE_CA_SEED=GENERATED_AT_INSTALL
MANIFEST_SIGNING_SEED=GENERATED_AT_INSTALL
RECOVERY_KEY=GENERATED_AT_INSTALL

FIRST_ADMIN_EMAIL=owner@example.com
FIRST_ADMIN_USERNAME=owner
FIRST_ADMIN_PASSWORD=GENERATE

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN_FILE=/opt/lumen/secrets/telegram-bot-token
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET_FILE=/opt/lumen/secrets/google-oauth-client-secret
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD_FILE=/opt/lumen/secrets/smtp-password
